<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>PHƯỚC CASINO - FINAL OPTIMIZED</title>

  <style>
    :root { 
      --gold: #ffd700; 
      --gold-dark: #bf953f; 
      --dark-emerald: #064e3b; 
    }
    * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Arial Black', sans-serif; user-select: none; }
    
    #rotate-warning { 
      display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; 
      background: #000; z-index: 9999; color: var(--gold);
      flex-direction: column; justify-content: center; align-items: center; text-align: center;
    }
    @media screen and (orientation: portrait) { #rotate-warning { display: flex; } }

    body { background: #000; color: white; height: 100vh; width: 100vw; display: flex; justify-content: center; align-items: center; overflow: hidden; }

    .container { 
      width: 98vw; height: 95vh; 
      background: radial-gradient(circle, #4a0000 0%, #1a0000 100%); 
      border: 4px double var(--gold); border-radius: 30px; padding: 10px; 
      display: flex; flex-direction: column; position: relative;
      transform: scale(0.8); /* Tổng thể giảm 20% */
      box-shadow: 0 0 30px rgba(255, 215, 0, 0.2);
    }
    
    .top-bar { display: flex; justify-content: space-between; align-items: center; height: 10%; padding: 0 20px; }
    .user-info { 
      background: linear-gradient(135deg, #000, #222); 
      padding: 5px 20px; border-radius: 30px; 
      border: 2px solid var(--gold); color: var(--gold); 
      font-weight: bold; font-size: 1.3rem;
    }

    .main-game { flex: 1; display: flex; justify-content: space-between; align-items: center; padding: 0 10px; }
    .side { width: 32%; text-align: center; display: flex; flex-direction: column; align-items: center; }
    
    .side-name { 
      font-size: 6.5rem; font-weight: 900; 
      color: #ffffff;
      text-shadow: 0 1px 0 #bbb, 0 2px 0 #aaa, 0 3px 0 #999, 0 4px 0 #888, 0 5px 0 #777, 0 10px 10px rgba(0,0,0,0.5);
      letter-spacing: -5px; line-height: 1; margin-bottom: 5px;
    }

    .bet-amount-display { 
      background: rgba(0,0,0,0.8); border: 2px solid var(--gold-dark); border-radius: 20px; 
      padding: 8px; color: var(--gold); font-size: 1.6rem; width: 100%; max-width: 220px;
      font-family: 'Courier New', monospace; font-weight: bold; margin-bottom: 8px;
    }

    /* Chữ CƯỢC nằm dưới số tiền */
    .bet-label {
      font-size: 2rem; color: var(--gold); cursor: pointer;
      text-shadow: 2px 2px 4px #000;
      padding: 4px 25px; border: 1px solid rgba(255, 215, 0, 0.3); border-radius: 12px;
      background: rgba(0,0,0,0.3); transition: 0.1s;
    }
    .bet-label:active { transform: scale(0.9); background: var(--gold); color: #000; }

    .center-bowl { width: 34%; display: flex; flex-direction: column; align-items: center; position: relative; }
    .circle-area { 
      width: 42vh; height: 42vh; background: rgba(0,0,0,0.3); 
      border-radius: 50%; border: 6px double var(--gold-dark); 
      position: relative; display: flex; justify-content: center; align-items: center; 
    }
    .bowl { 
      width: 43vh; height: 43vh; 
      background: radial-gradient(circle at 35% 35%, #555, #111); 
      border-radius: 50%; position: absolute; z-index: 10; cursor: grab; touch-action: none; 
      box-shadow: 0 15px 30px rgba(0,0,0,0.7); border: 2px solid #333;
    }
    
    .timer-floating {
      position: absolute; z-index: 20; top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      font-size: 4rem; color: var(--gold); font-weight: bold;
      text-shadow: 0 0 20px #000, 0 0 10px #000; pointer-events: none;
    }

    .dice-container { display: none; flex-wrap: wrap; width: 14vh; justify-content: center; gap: 10px; z-index: 5; }
    .dice { width: 6vh; height: 6vh; background: #fff; border-radius: 8px; position: relative; }
    .dot { width: 1.2vh; height: 1.2vh; background: #cc0000; border-radius: 50%; position: absolute; }

    /* Lịch sử soi cầu tăng chiều rộng 10% */
    .soi-cau-container { 
      width: 90%; height: 45px; background: rgba(0,0,0,0.7); 
      border-radius: 25px; padding: 0 15px; border: 1px solid var(--gold-dark); 
      margin: 8px auto; display: flex; align-items: center; justify-content: center;
      gap: 10px; overflow: hidden;
    }
    .cau-item { width: 24px; height: 24px; border-radius: 50%; font-size: 11px; display: flex; align-items: center; justify-content: center; font-weight: bold; flex-shrink: 0; }
    .cau-tai { background: #000; color: #fff; border: 1px solid #fff; }
    .cau-xiu { background: #fff; color: #000; border: 1px solid #000; }

    /* Chip giảm kích thước 20% (~48px) */
    .chip-container { display: flex; justify-content: center; gap: 12px; margin-bottom: 10px; height: 12%; align-items: center; }
    .chip { 
      width: 48px; height: 48px; border-radius: 50%; 
      display: flex; justify-content: center; align-items: center; 
      font-size: 0.65rem; font-weight: bold; cursor: pointer; color: #fff; 
      border: 2px solid rgba(255,255,255,0.2); 
      background: radial-gradient(circle, #065f46 0%, #064e3b 100%); 
      box-shadow: 0 4px 8px rgba(0,0,0,0.5); transition: 0.2s;
    }
    .chip.selected { border: 2px solid var(--gold); box-shadow: 0 0 12px var(--gold); transform: translateY(-3px); }

    #betStatus { height: 30px; font-weight: bold; color: var(--gold); font-size: 1.5rem; margin-top: 10px; text-align: center;}
  </style>
</head>
<body>

  <div id="rotate-warning"><h1>XOAY NGANG MÀN HÌNH</h1></div>

  <div class="container">
    <div class="top-bar">
      <div class="user-info">💰 <span id="coin">0</span></div>
      <h3 style="color: var(--gold); font-size: 1.1rem;">PHƯỚC CASINO ROYAL</h3>
      <button onclick="addMoney()" style="background: var(--gold); border:none; padding: 4px 12px; border-radius: 6px; font-weight: bold; cursor: pointer;">NẠP TIỀN</button>
    </div>

    <div class="main-game">
      <div class="side">
        <div class="side-name">TÀI</div>
        <div class="bet-amount-display" id="redBet">0</div>
        <div class="bet-label" onclick="confirmBet('TÀI')">CƯỢC</div>
      </div>

      <div class="center-bowl">
        <div class="circle-area">
          <div class="timer-floating" id="timerText">30</div>
          <div class="bowl" id="bowl"></div>
          <div class="dice-container" id="diceContainer">
            <div class="dice" id="d1"></div>
            <div class="dice" id="d2"></div>
            <div class="dice" id="d3"></div>
          </div>
        </div>
        <div id="betStatus"></div>
      </div>

      <div class="side">
        <div class="side-name">XỈU</div>
        <div class="bet-amount-display" id="greenBet">0</div>
        <div class="bet-label" onclick="confirmBet('XỈU')">CƯỢC</div>
      </div>
    </div>

    <div class="soi-cau-container" id="cauList"></div>

    <div class="chip-container">
      <div class="chip" onclick="selectChip(10000, this)">10K</div>
      <div class="chip" onclick="selectChip(50000, this)">50K</div>
      <div class="chip" onclick="selectChip(100000, this)">100K</div>
      <div class="chip" onclick="selectChip(500000, this)">500K</div>
      <div class="chip" onclick="selectChip(1000000, this)">1M</div>
      <div class="chip" onclick="selectChip(10000000, this)">10M</div>
      <div class="chip" style="background:#000; border-color:var(--gold)" onclick="selectChip('ALL', this)">ALL</div>
    </div>
  </div>

  <script>
    let coins = 0, selectedAmount = 0, countdown = 30;
    let redTotal = 0, greenTotal = 0, isNanned = false, canOpen = false;
    let currentResult = '';
    let bowlX = 0, bowlY = 0, isDragging = false, startX, startY;
    let historyData = [];

    const format = (n) => n.toLocaleString();
    document.getElementById('coin').innerText = format(coins);

    function selectChip(amt, el) {
      if (countdown <= 3) return;
      document.querySelectorAll('.chip').forEach(c => c.classList.remove('selected'));
      el.classList.add('selected');
      selectedAmount = amt;
    }

    function confirmBet(side) {
      if (countdown <= 3) return;
      if (selectedAmount === 0) return;
      let amt = (selectedAmount === 'ALL') ? coins : selectedAmount;
      if (amt <= 0 || amt > coins) return;
      
      coins -= amt;
      if (side === 'TÀI') redTotal += amt;
      else greenTotal += amt;
      
      document.getElementById('coin').innerText = format(coins);
      document.getElementById('redBet').innerText = format(redTotal);
      document.getElementById('greenBet').innerText = format(greenTotal);
    }

    function startNewGame() {
      countdown = 30; canOpen = false; isNanned = false;
      redTotal = 0; greenTotal = 0;
      document.getElementById('redBet').innerText = '0';
      document.getElementById('greenBet').innerText = '0';
      document.getElementById('betStatus').innerText = '';
      document.getElementById('diceContainer').style.display = 'none';
      document.getElementById('timerText').style.display = 'block';
      let bowl = document.getElementById('bowl');
      bowl.style.transition = '0.5s'; bowl.style.transform = 'translate(0,0)';
      bowlX = 0; bowlY = 0;

      let d = [Math.floor(Math.random()*6)+1, Math.floor(Math.random()*6)+1, Math.floor(Math.random()*6)+1];
      currentResult = (d[0]+d[1]+d[2] >= 11) ? 'TÀI' : 'XỈU';
      d.forEach((val, i) => renderDice('d'+(i+1), val));

      let timer = setInterval(() => {
        countdown--;
        document.getElementById('timerText').innerText = countdown;
        if (countdown <= 0) {
          clearInterval(timer);
          document.getElementById('timerText').innerText = "MỞ";
          canOpen = true;
          document.getElementById('diceContainer').style.display = 'flex';
        }
      }, 1000);
    }

    function renderDice(id, n) {
      const el = document.getElementById(id); el.innerHTML = '';
      const dots = { 1:[[40,40]], 2:[[15,15],[65,65]], 3:[[15,15],[40,40],[65,65]], 4:[[15,15],[65,15],[15,65],[65,65]], 5:[[15,15],[65,15],[40,40],[15,65],[65,65]], 6:[[15,15],[65,15],[15,40],[65,40],[15,65],[65,65]] };
      dots[n].forEach(p => { 
        let dot = document.createElement('div'); dot.className='dot'; 
        dot.style.left=p[0]+'%'; dot.style.top=p[1]+'%'; el.appendChild(dot); 
      });
    }

    function finishGame() {
      if (isNanned) return; isNanned = true;
      document.getElementById('timerText').style.display = 'none';
      historyData.push(currentResult);
      if (historyData.length > 20) historyData.shift();
      const listEl = document.getElementById('cauList');
      listEl.innerHTML = '';
      historyData.forEach(res => {
        let item = document.createElement('div');
        item.className = `cau-item ${res === 'TÀI' ? 'cau-tai' : 'cau-xiu'}`;
        item.innerText = res[0];
        listEl.appendChild(item);
      });

      let win = 0;
      if (redTotal > 0 && currentResult === 'TÀI') win = redTotal * 1.95;
      if (greenTotal > 0 && currentResult === 'XỈU') win = greenTotal * 1.95;
      if (win > 0) { coins += win; document.getElementById('betStatus').innerText = "WIN +" + format(win); }
      document.getElementById('coin').innerText = format(coins);
      setTimeout(startNewGame, 4000);
    }

    const bowlEl = document.getElementById('bowl');
    const onStart = (e) => { if (!canOpen || isNanned) return; isDragging = true; bowlEl.style.transition = 'none'; let ev = e.touches ? e.touches[0] : e; startX = ev.clientX - bowlX; startY = ev.clientY - bowlY; };
    const onMove = (e) => { if (!isDragging) return; let ev = e.touches ? e.touches[0] : e; bowlX = ev.clientX - startX; bowlY = ev.clientY - startY; bowlEl.style.transform = `translate(${bowlX}px, ${bowlY}px) rotate(${bowlX/4}deg)`; };
    const onEnd = () => {
      if (!isDragging) return; isDragging = false;
      if (Math.abs(bowlX) > 80 || Math.abs(bowlY) > 80) {
        bowlEl.style.transition = '0.6s'; bowlEl.style.transform = `translate(${bowlX*2.5}px, ${bowlY*2.5}px)`;
        finishGame();
      } else {
        bowlEl.style.transition = '0.3s'; bowlEl.style.transform = 'translate(0,0)'; bowlX = 0; bowlY = 0;
      }
    };

    bowlEl.addEventListener('mousedown', onStart); window.addEventListener('mousemove', onMove); window.addEventListener('mouseup', onEnd);
    bowlEl.addEventListener('touchstart', onStart); window.addEventListener('touchmove', onMove, { passive: false }); window.addEventListener('touchend', onEnd);
    function addMoney() { coins += 5000000; document.getElementById('coin').innerText = format(coins); }
    startNewGame();
  </script>
</body>
</html>
